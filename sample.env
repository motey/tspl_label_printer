# ----------------------------------------------------------------------------
# TSPL Label Printer — sample configuration
#
# Copy this file to ".env" (in the tspl_printer_service/ directory) and adjust:
#     cp tspl_printer_service/sample.env tspl_printer_service/.env
#
# Only PRINTER_USB is required; every other setting is shown with its default
# (commented out) — uncomment a line to override it.
# ----------------------------------------------------------------------------

# === Printer (REQUIRED) =====================================================
# Which USB printer to drive. The most robust selector is vendor:product id,
# because it survives replugging (a bus/address changes). Find your ids with
# `lsusb`, e.g. "ID 2d37:62de" -> vid:2d37:pid:62de.
#
# Supported forms:
#   vid:2d37:pid:62de            vendor + product id  (recommended)
#   vid:2d37                     vendor id only (first match)
#   serial:ABC123456             USB serial number
#   port:3-1-2                   USB port path (stable per physical port)
#   path:/dev/bus/usb/001/015    kernel device path (changes on replug)
#   bus:1:addr:15                bus + address (changes on replug)
PRINTER_USB=vid:2d37:pid:62de

# === Web server =============================================================
# Bind host. Use 0.0.0.0 to expose the API on your LAN.
#SERVER_LISTENING_HOST=localhost
# API port.
#SERVER_LISTENING_PORT=8888

# === Authentication =========================================================
# !!! DEFAULT IS OPEN — NO AUTHENTICATION !!!
# With AUTH_MODE=open (the default) every API endpoint AND the whole web UI are
# public to anyone who can reach the host. Fine for a trusted home LAN; do NOT
# expose it to the internet/untrusted networks in this mode.
#
# AUTH_MODE: "open" (no auth) or "protected" (a valid credential is required).
#AUTH_MODE=open
#
# In protected mode, ANY configured provider can authenticate a request:
#
#   API tokens (machines/scripts) — sent as `Authorization: Bearer <token>`.
#   JSON list of {name, token}:
#AUTH_TOKENS=[{"name":"ci","token":"choose-a-long-random-secret"}]
#
#   Local users (humans) — log in at /login; a session cookie keeps them in.
#   Generate password_hash with:  uv run labeljetty-hash-password
#AUTH_USERS=[{"username":"tim","password_hash":"pbkdf2_sha256$600000$...$..."}]
#
# Secret used to sign session cookies. Leave unset for an ephemeral random one
# (logins reset on restart); set a stable random value in production.
#SESSION_SECRET=
#SESSION_COOKIE_NAME=labeljetty_session
#SESSION_MAX_AGE=1209600
#
# (Planned: AUTH_OIDC_* for OIDC/SSO as a drop-in provider — not yet implemented.)

# === Storage ================================================================
# Paths are resolved relative to the current working directory — run the
# service from the same directory each time, or use absolute paths here.
# Job-queue sqlite database.
#SQLITE_PATH=./printjobs.sqlite
# Directory where uploaded print files (png/pdf) are stored.
#IMAGE_STORAGE_DIRECTORY=./../images
# Auto-delete jobs (and their stored files) older than this many days.
#DELETE_OLD_JOBS_AFTER_DAYS=100

# === Default label geometry =================================================
# Used when a print job does not specify its own size/resolution.
#DEFAULT_LABEL_WIDTH_MM=100
#DEFAULT_LABEL_HEIGHT_MM=30
#DEFAULT_DPI=203

# Named label profiles selectable in the web UI (JSON list). The server default
# geometry above is always offered as a "Default" profile in addition to these.
#LABEL_PROFILES=[{"name":"Homebox","width_mm":57,"height_mm":32},{"name":"DHL Versandmarke","width_mm":100,"height_mm":50}]

# === Homebox integration (optional module) ==================================
# The Homebox section in the web UI + the pull endpoints appear only when
# HOMEBOX_URL and HOMEBOX_API_KEY are both set (and HOMEBOX_ENABLED is true).
#HOMEBOX_ENABLED=true
# Base URL of your Homebox server (v0.26+, entity-merged API).
#HOMEBOX_URL=https://box.example.com
# Homebox API key (prefixed 'hb_…'). The server admin must have set
# HBOX_AUTH_API_KEY_PEPPER (>=32 chars) for API keys to work at all.
#HOMEBOX_API_KEY=hb_xxxxxxxxxxxx
# API path prefix on the Homebox server (entities live at <prefix>/entities,
# and labels at <prefix>/labelmaker/{item,location,asset}/{id}).
#HOMEBOX_API_PREFIX=/api/v1
# Web path an entity opens at (appended to HOMEBOX_URL); '{id}' is substituted.
# Used only for the "open in Homebox" link beside search results.
#HOMEBOX_ENTITY_URL_TEMPLATE=/item/{id}
# Push "external label service": also enqueue the print when Homebox requests
# the label image. Set false if your Homebox build calls the label-service URL
# for previews too (would cause spurious prints) — use the print-command script
# (Option C on the /ui/homebox/setup page) instead.
#HOMEBOX_LABEL_SERVICE_AUTOPRINT=true

# === Logging ================================================================
# App log level: CRITICAL | ERROR | WARNING | INFO | DEBUG
#LOG_LEVEL=DEBUG
# Disable ANSI colours in log output (useful when logging to a file/journal).
#LOG_DISABLE_COLORS=false
# Uvicorn (web server) log level. Defaults to LOG_LEVEL when unset.
#UVICORN_LOG_LEVEL=
# Display name of the application (used in logs).
#APP_NAME=TSPL Printer WebAPI
